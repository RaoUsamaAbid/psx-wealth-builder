# Copy to .env and fill in. Never commit the real .env.
NODE_ENV=development

# API
API_PORT=4000
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173

# MongoDB Atlas — get connection string from Atlas dashboard
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/psx_wealth_builder?retryWrites=true&w=majority
MONGODB_DB=psx_wealth_builder

# Redis
REDIS_URL=redis://localhost:6379

# Market data provider: mock | capitalstake | realtime
MARKET_DATA_PROVIDER=mock

# Web
VITE_API_URL=http://localhost:4000
