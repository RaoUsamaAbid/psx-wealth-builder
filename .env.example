# Copy to .env and fill in. Never commit the real .env.
NODE_ENV=development

# API
API_PORT=4000
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173

# MongoDB Atlas — get connection string from Atlas dashboard
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/psx_wealth_builder?retryWrites=true&w=majority
MONGODB_DB=psx_wealth_builder

MARKET_REFRESH_MS=5000
QUOTE_FRESHNESS_MS=20000

# Web
VITE_API_URL=http://localhost:4000

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
